{
  "name": "amazon-playwright-tests",
  "version": "1.0.0",
  "description": "Playwright test automation suite for Amazon shopping cart scenarios with parallel execution and LambdaTest cloud integration",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:parallel": "playwright test --workers=2",
    "test:headed": "playwright test --headed",
    "test:lambdatest": "LAMBDATEST=true playwright test",
    "test:report": "playwright test && playwright show-report",
    "lint": "eslint tests/ pages/ utils/"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "amazon",
    "lambdatest"
  ],
  "author": "AJ",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "eslint": "^8.57.0"
  },
  "dependencies": {
    "dotenv": "^16.6.1"
  }
}
