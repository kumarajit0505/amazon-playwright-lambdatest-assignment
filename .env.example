# ─────────────────────────────────────────────────────────────────────────────
# Environment Variables — copy this file to .env and fill in your values.
# .env is listed in .gitignore and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── LambdaTest Credentials ───────────────────────────────────────────────────
# Obtain these from https://accounts.lambdatest.com/detail/profile
LT_USERNAME=your_lambdatest_username
LT_ACCESS_KEY=your_lambdatest_access_key

# ── Execution Target ─────────────────────────────────────────────────────────
# Set to "true" to route tests through LambdaTest cloud infrastructure.
# Leave unset or set to "false" to run locally.
LAMBDATEST=false
